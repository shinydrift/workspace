{
  "name": "agentos",
  "productName": "AgentOS",
  "version": "1.0.10",
  "description": "My Electron application description",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "check:memory": "node scripts/check-memory-smoke.mjs",
    "setup:mac": "bash scripts/setup-macos.sh",
    "start": "electron-forge start",
    "test": "node --test 'tests/**/*.test.mjs'",
    "test:watch": "node --test --watch 'tests/**/*.test.mjs'",
    "test:ts": "node --import tsx --test 'tests/main/**/*.test.ts' 'tests/preload/**/*.test.ts' 'tests/shared/**/*.test.ts' 'tests/sessions/**/*.test.ts' 'tests/integrations/**/*.test.ts' 'tests/automations/**/*.test.ts' 'tests/scripts/**/*.test.ts'",
    "test:coverage": "c8 --config .c8rc.json node --import tsx --test 'tests/**/*.test.mjs' 'tests/main/**/*.test.ts' 'tests/preload/**/*.test.ts' 'tests/shared/**/*.test.ts' 'tests/sessions/**/*.test.ts' 'tests/integrations/**/*.test.ts' 'tests/automations/**/*.test.ts' 'tests/scripts/**/*.test.ts'",
    "test:renderer": "vitest run --config vitest.renderer.config.ts",
    "test:renderer:coverage": "vitest run --config vitest.renderer.config.ts --coverage",
    "package": "electron-forge package",
    "package:mac": "npm run package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "rebuild": "node -e \"require('@electron/rebuild').rebuild({ buildPath: process.cwd(), electronVersion: require('./node_modules/electron/package.json').version, force: true }).then(() => console.log('Done')).catch(e => { console.error(e.message); process.exit(1); })\"",
    "prepare": "git -C .. config core.hooksPath agentos/.husky && chmod +x .husky/pre-commit"
  },
  "keywords": [],
  "author": "pradeepgodara",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.5.0",
    "@electron-forge/maker-deb": "^7.5.0",
