{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "outDir": "dist",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "types": ["node"],
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/renderer/*"],
      "@shared/*": ["./src/shared/*"],
      "@components/*": ["./src/renderer/components/*"],
      "@hooks/*": ["./src/renderer/hooks/*"],
      "@store/*": ["./src/renderer/store/*"]
    }
  },
  "include": ["src/**/*", "resources/**/*.d.ts", "forge.env.d.ts", "forge.config.ts", "vite.*.config.ts"]
}
