{
    "display_information": {
        "name": "AgentOS",
        "description": "Isolated, observable, autonomous — your AI agents, on rails.",
        "background_color": "#000000"
    },
    "features": {
        "bot_user": {
            "display_name": "AgentOS",
            "always_online": true
        }
    },
    "oauth_config": {
        "scopes": {
            "bot": [
                "files:read",
                "app_mentions:read",
                "channels:history",
                "channels:read",
                "chat:write",
                "groups:history",
                "groups:read",
                "im:history",
                "mpim:history",
                "reactions:write"
            ]
        },
        "pkce_enabled": false
    },
    "settings": {
        "event_subscriptions": {
            "bot_events": [
                "app_mention",
                "message.channels",
                "message.groups",
                "message.im",
                "message.mpim"
            ]
        },
        "interactivity": {
            "is_enabled": true
        },
        "org_deploy_enabled": false,
        "socket_mode_enabled": true,
        "token_rotation_enabled": false,
        "is_mcp_enabled": false
    }
}
